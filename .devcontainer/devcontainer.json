{
  "name": "Python Learn 2026",
  "image": "://mcr.microsoft.com",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "pip3 install --user -r requirements.txt",
  "forwardPorts": [5000]
}
